html
    head
        title #{title || 'SD2 Lab 4'}
        style.
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                margin: 0;
                padding: 40px 20px;
                background-color: #f4f6f8;
                color: #333;
            }
            .wrapper {
                max-width: 800px;
                margin: 0 auto;
                background: #ffffff;
                padding: 40px;
                border-radius: 6px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
                border: 1px solid #e1e4e8;
            }
            h1 {
                color: #1a202c;
                font-size: 28px;
                margin-top: 0;
                margin-bottom: 20px;
                padding-bottom: 12px;
                border-bottom: 2px solid #e2e8f0;
            }
            h3 {
                color: #2d3748;
                margin-top: 35px;
                margin-bottom: 15px;
                font-size: 18px;
                font-weight: 600;
            }
            /* Explicit, clean table styles to ensure it looks like a real table */
            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 15px;
                background-color: #fff;
                border: 1px solid #cbd5e1;
            }
            th, td {
                padding: 12px 15px;
                text-align: left;
                border: 1px solid #cbd5e1; /* Clear gridlines */
            }
            th {
                background-color: #f1f5f9; /* Soft gray header background */
                color: #334155;
                font-weight: 600;
            }
            tr:nth-child(even) {
                background-color: #f8fafc; /* Alternating row colors */
            }
            /* Clean list styles */
            ul {
                list-style-type: disc;
                padding-left: 20px;
                margin: 15px 0;
            }
            li {
                padding: 8px 0;
                font-size: 15px;
            }
    body
        div.wrapper
            block content