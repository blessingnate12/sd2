extends layout

block content
    h1 Database Test Results

    h3 Exercise 1: Bullet Point List of Student Names
    ul
        each item in data
            li #{item.name}

    h3 Exercise 2: Student Data Table
    table
        thead
            tr
                th(style="width: 25%") Student ID
                th Student Name
        tbody
            each item in data
                tr
                    td #{item.id}
                    td #{item.name}